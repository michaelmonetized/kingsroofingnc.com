{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "ignoreUnknown": true, "includes": ["**", "!node_modules", "!.next", "!.vercel", "!out", "!build", "!coverage", "!bun.lock", "!tsconfig.tsbuildinfo", "!next-env.d.ts", "!convex/_generated"] },
  "formatter": { "enabled": true, "indentStyle": "space", "lineWidth": 100 },
  "css": { "parser": { "tailwindDirectives": true } },
  "linter": { "enabled": true, "rules": { "recommended": true } },
  "javascript": { "formatter": { "quoteStyle": "double", "semicolons": "always", "trailingCommas": "all" } }
}
