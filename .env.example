# Kings Roofing NC — Environment Variables
# Copy this file to .env.local and fill in real values

# Resend email (for contact form submissions)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe payments (for premium quote requests)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx or pk_live_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx or sk_live_xxxx
NEXT_PUBLIC_URL=http://localhost:3000 (production: https://kingsroofingnc.com)

# Optional: PostHog analytics
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_API_HOST=https://app.posthog.com

# Optional: Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
